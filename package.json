{
  "name": "@sbroenne/dvq",
  "version": "0.1.4",
  "description": "CLI for querying Dataverse OData endpoints with Azure CLI credentials",
  "type": "module",
  "bin": {
    "dvq": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/lib.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run test:unit",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run lint && npm run build && npm test",
    "test:unit": "vitest run --exclude src/lib.integration.test.ts",
    "test:integration": "vitest run src/lib.integration.test.ts",
    "format:check": "prettier --check 'src/**/*.ts'",
    "lint:fix": "eslint src/ --fix"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "dataverse",
    "query",
    "odata",
    "dynamics365",
    "cli",
    "azure"
  ],
  "homepage": "https://github.com/sbroenne/dvq",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sbroenne/dvq.git"
  },
  "bugs": {
    "url": "https://github.com/sbroenne/dvq/issues"
  },
  "author": "sbroenne",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
