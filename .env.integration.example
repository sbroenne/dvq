# Integration test configuration
# Copy this file to .env.integration and fill in real values to enable integration tests

# Enable integration tests (required to run them)
RUN_INTEGRATION_TESTS=true

# Your Dataverse environment URL
DATAVERSE_URL=https://yourorg.crm.dynamics.com

# Optional: specify a different tenant for az login context
# AZURE_TENANT_ID=your-tenant-guid-here
